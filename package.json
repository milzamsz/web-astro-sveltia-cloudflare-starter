{
  "name": "astro-sveltia-cloudflare",
  "version": "0.0.1",
  "private": true,
  "description": "Multilingual marketing website with Astro, Sveltia CMS, Cloudflare Pages",
  "license": "MIT",
  "packageManager": "pnpm@8.15.0",
  "type": "module",
  "engines": {
    "node": "24.0.0",
    "pnpm": "8.15.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "pnpm run lint:js && pnpm run lint:css && pnpm run type-check && pnpm run validate:i18n && pnpm run validate:secrets",
    "lint:js": "eslint --ext .js,.jsx,.ts,.tsx src/",
    "lint:css": "stylelint src/",
    "type-check": "astro check",
    "format": "prettier --write 'src/**/*.{astro,ts,tsx,css}'",
    "format:check": "prettier --check 'src/**/*.{astro,ts,tsx,css}'",
    "validate:i18n": "node scripts/validate-i18n.js",
    "validate:cms": "node scripts/validate-cms-config.cjs",
    "validate:secrets": "node scripts/validate-secrets.cjs",
    "postbuild": "pagefind --site dist && node scripts/generate-media-manifest.cjs && node scripts/generate-llms-txt.cjs"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^7.0.2",
    "better-auth": "^1.6.20",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.2.1",
    "@astrojs/starlight": "^0.41.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "pagefind": "^1.5.2",
    "prettier": "^3.0.0",
    "prettier-plugin-astro": "^0.12.0",
    "stylelint": "^15.0.0",
    "stylelint-config-prettier": "^9.0.0",
    "typescript": "^5.0.0"
  }
}