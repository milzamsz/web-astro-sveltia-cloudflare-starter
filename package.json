{
  "name": "astro-sveltia-cloudflare",
  "version": "0.0.1",
  "private": true,
  "description": "Multilingual marketing website with Astro, Sveltia CMS, Cloudflare Pages",
  "license": "MIT",
  "packageManager": "pnpm@8.15.0",
  "type": "module",
  "engines": {
    "node": "24.0.0",
    "pnpm": "8.15.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "pnpm run lint:js && pnpm run lint:css && pnpm run type-check && pnpm run check:kpis && pnpm run validate:i18n && pnpm run validate:secrets",
    "lint:js": "eslint . --ignore-pattern dist --ignore-pattern .astro --ignore-pattern .wrangler --ignore-pattern node_modules",
    "lint:css": "stylelint src/styles/",
    "check:kpis": "node scripts/check-kpis.mjs",
    "type-check": "astro check",
    "format": "prettier --write 'src/**/*.{astro,ts,tsx,css}'",
    "format:check": "prettier --check 'src/**/*.{astro,ts,tsx,css}'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "validate:i18n": "node scripts/validate-i18n.js",
    "validate:cms": "node scripts/validate-cms-config.cjs",
    "validate:secrets": "node scripts/validate-secrets.cjs",
    "postbuild": "node scripts/generate-media-manifest.cjs && node scripts/generate-llms-txt.cjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/react": "^6.0.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/jetbrains-mono": "^5.2.0",
    "@fontsource-variable/manrope": "^5.2.0",
    "@fontsource-variable/outfit": "^5.2.0",
    "@iconify-json/lucide": "^1.2.114",
    "@iconify-json/simple-icons": "^1.2.87",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^7.0.2",
    "astro-icon": "^1.1.5",
    "better-auth": "^1.6.20",
    "clsx": "^2.1.1",
    "cva": "1.0.0-beta.4",
    "react": "19",
    "react-dom": "19",
    "schema-dts": "^1.1.3",
    "sharp": "^0.34.1",
    "tailwind-merge": "^3.2.0",
    "tailwindcss": "^4.3.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/starlight": "^0.41.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.53.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "astro-eslint-parser": "^2.1.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.3.1",
    "globals": "^16.0.0",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "stylelint": "^17.14.0",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.4.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.1.0"
  }
}