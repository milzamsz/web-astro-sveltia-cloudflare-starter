# Cloudflare Pages Environment Variables
# Copy to .env.local (not committed) for local development

# GitHub (for Sveltia CMS content access)
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# Token handed to authenticated editors' browsers so they can commit content
# via Sveltia (email/password-only login model). Use a FINE-GRAINED PAT scoped
# to the content repo with Contents: read/write only. Keep it distinct from the
# privileged GITHUB_PAT below.
GITHUB_CMS_TOKEN=

# Server-only PAT used for the publish workflow (merge content-preview -> main).
# Never delivered to the browser. Needs Contents: read/write on the content repo.
GITHUB_PAT=

# Legacy GitHub OAuth (only needed if you switch back to the real GitHub OAuth
# login flow instead of the email/password SSO bridge).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Resend (email service)
RESEND_API_KEY=

# Cloudflare Turnstile (contact form protection)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google Maps (contact page)
GOOGLE_MAPS_API_KEY=

# Analytics (optional)
ANALYTICS_ENDPOINT=
ANALYTICS_API_KEY=