# Cloudflare Pages Environment Variables
# Copy to .env.local (not committed) for local development

# GitHub (for Sveltia CMS content access)
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# GitHub OAuth (for CMS authentication flow)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Resend (email service)
RESEND_API_KEY=

# Cloudflare Turnstile (contact form protection)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google Maps (contact page)
GOOGLE_MAPS_API_KEY=

# Analytics (optional)
ANALYTICS_ENDPOINT=
ANALYTICS_API_KEY=