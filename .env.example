# Environment variables
# ---------------------------------------------------------------------------
# Local dev: copy to .env (not committed).
# Production: set these in Cloudflare Pages → Settings → Environment variables.
# Secrets (auth, PATs, API keys) must be set as encrypted secrets in Cloudflare,
# never committed.
#
# Cloudflare bindings (NOT env vars — configure in Pages/wrangler):
#   DB        → D1 database (auth, sessions, 2FA, contacts)
#   R2_MEDIA  → R2 bucket (CMS media + cleanup worker)

# --- Site -----------------------------------------------------------------
# Public production URL. Falls back to http://localhost:4321 in dev.
# Canonical/OG/sitemap also read src/config/site.config.ts (url).
SITE_URL=

# --- GitHub / Sveltia CMS -------------------------------------------------
# Content repo + branch used by the CMS and publish workflow.
SVELTIA_BACKEND_REPO=owner/repo
SVELTIA_BACKEND_BRANCH=main

# Fine-grained PAT handed to authenticated editors' browsers so they can commit
# content via Sveltia (email/password-only login). Scope: Contents read/write
# on the content repo ONLY. Keep distinct from GITHUB_PAT.
GITHUB_CMS_TOKEN=

# Server-only PAT for the publish workflow (merge content-preview -> main).
# Never delivered to the browser. Scope: Contents read/write on the content repo.
GITHUB_PAT=

# Legacy GitHub OAuth (only if you switch back to real GitHub OAuth login
# instead of the email/password SSO bridge).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# --- Auth (Better Auth) ---------------------------------------------------
# Strong random string for signing sessions. Generate, e.g.:
#   node -e "console.log(crypto.randomBytes(32).toString('hex'))"
SESSION_SECRET=
# Issuer name shown in authenticator apps for TOTP 2FA.
TOTP_ISSUER=Astro Sveltia Cloudflare

# --- Email (Resend) -------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Cloudflare Turnstile (login + contact form) --------------------------
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- R2 media cleanup worker (functions/api/cleanup.ts) -------------------
# CF API token + account ID used to trigger rebuilds / manage media.
CF_ACCOUNT_ID=
CF_API_TOKEN=
# dry-run | quarantine | delete
CLEANUP_MODE=dry-run
CLEANUP_GRACE_DAYS=30

# --- SEO verification (optional) ------------------------------------------
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# --- Contact page (optional) ----------------------------------------------
GOOGLE_MAPS_API_KEY=

# --- Analytics & consent (optional, client-side) --------------------------
PUBLIC_GA_MEASUREMENT_ID=
PUBLIC_GTM_ID=
PUBLIC_CONSENT_ENABLED=false
PUBLIC_PRIVACY_POLICY_URL=
