# Required for local development
SESSION_SECRET=your-32-char-secret-here-generate-with-openssl-rand-base64-32
TOTP_ISSUER=MyApp

# Optional: set these for local auth/contact testing
# RESEND_API_KEY=re_...
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET_NAME=...
# TURNSTILE_SECRET_KEY=0x4AAA...
# PUBLIC_TURNSTILE_SITE_KEY=0x4AAA...

# Analytics (optional)
# ANALYTICS_PROVIDER=gtm|umami|none
# ANALYTICS_ID=G-XXXXXXXXXX|your-site-id

# Preview mode (optional)
# PUBLIC_ENABLE_PREVIEW=false