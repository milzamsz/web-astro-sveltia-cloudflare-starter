---
import type { Locale } from "../lib/site-config";
import { resolveRoute } from "../i18n/routes";
import CTA from "./ui/marketing/CTA/CTA.astro";

export interface Props {
  title: string;
  content?: string;
  ctaText?: string;
  ctaHref?: string;
  locale: Locale;
}

const { title, content, ctaText, ctaHref, locale } = Astro.props;
---

<CTA
  title={title}
  content={content}
  primaryText={ctaText}
  primaryHref={ctaHref ? resolveRoute(locale, ctaHref) : undefined}
  centered={true}
/>
