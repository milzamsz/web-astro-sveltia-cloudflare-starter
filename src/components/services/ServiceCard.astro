---
import type { CollectionEntry } from "astro:content";
import { Card, Badge } from "../ui/index";
import { resolveRoute } from "../../i18n/routes";
import { type Locale } from "../../lib/site-config";
import { t } from "../../i18n/ui";

export interface Props {
  service: CollectionEntry<"services">;
  locale?: Locale;
  /** Heading level for the card title; use "h2" when cards sit directly under the page h1. */
  headingLevel?: "h2" | "h3";
}

const {
  service,
  locale = service.data.locale,
  headingLevel = "h3",
} = Astro.props as Props;
const Heading = headingLevel;
---

<Card hover={true} class="service-card">
  <div class="service-card__body">
    <p class="service-card__eyebrow">
      {locale === "id" ? "Layanan" : "Service"}
    </p>
    <Heading class="service-card__title">
      <a href={resolveRoute(locale, `/services/${service.data.slug}`)}
        >{service.data.title}</a
      >
    </Heading>
    <p class="service-card__description">{service.data.description}</p>
    {
      service.data.priceRange && (
        <Badge variant="secondary">
          {t(locale, "services.priceRange")}: {service.data.priceRange}
        </Badge>
      )
    }
    {
      service.data.features.length > 0 && (
        <ul class="service-card__features">
          <li class="service-card__features-label">
            {t(locale, "services.features")}
          </li>
          {service.data.features.slice(0, 3).map((feature: string) => (
            <li>{feature}</li>
          ))}
        </ul>
      )
    }
    <a
      class="service-card__cta"
      href={resolveRoute(locale, `/services/${service.data.slug}`)}
      aria-label={`${t(locale, "services.learnMore")}: ${service.data.title}`}
    >
      {t(locale, "services.learnMore")}
    </a>
  </div>
</Card>

<style>
  .service-card__body {
    display: grid;
    gap: var(--space-sm);
  }

  .service-card__eyebrow {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.75rem;
    color: var(--color-brand-primary);
    font-weight: 700;
  }

  .service-card__title {
    margin: 0;
    font-size: 1.25rem;
  }

  .service-card__title a {
    color: inherit;
    text-decoration: none;
  }

  .service-card__description {
    margin: 0;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .service-card__features {
    display: grid;
    gap: 0.5rem;
    margin: 0;
    padding-left: 1rem;
    color: var(--color-text-secondary);
  }

  .service-card__cta {
    width: fit-content;
    color: var(--color-brand-primary);
    text-decoration: none;
    font-weight: 700;
  }
</style>
