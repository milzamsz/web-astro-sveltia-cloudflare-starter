---
import type { Locale } from "../lib/site-config";
import { SITE_CONFIG } from "../lib/site-config";
import { t } from "../i18n/ui";
import { resolveRoute } from "../i18n/routes";

export interface Props {
  currentLocale: Locale;
}

const { currentLocale } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <strong>{SITE_CONFIG.name}</strong>
      <span class="footer__tagline">{t(currentLocale, "footer.tagline")}</span>
    </div>

    <div class="footer__bottom">
      <p>&copy; {year} {SITE_CONFIG.name}. All rights reserved.</p>
      <nav aria-label="Legal">
        <a href={resolveRoute(currentLocale, "/privacy")}>
          {t(currentLocale, "footer.privacy")}
        </a>
        <a href={resolveRoute(currentLocale, "/terms")}>
          {t(currentLocale, "footer.terms")}
        </a>
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
    margin-top: auto;
  }

  .footer__inner {
    padding-block: var(--space-xl) var(--space-lg);
  }

  .footer__brand {
    margin-bottom: var(--space-lg);
  }

  .footer__tagline {
    display: block;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    margin-top: var(--space-xs);
  }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-lg);
  }

  .footer__bottom nav {
    display: flex;
    gap: var(--space-lg);
  }

  .footer__bottom a {
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .footer__bottom a:hover {
    color: var(--color-brand-primary);
  }
</style>
