---
import type { Locale } from "../lib/site-config";
import { SITE_CONFIG } from "../lib/site-config";
import { t } from "../i18n/ui";
import { resolveRoute, detectLocale } from "../i18n/routes";
import { getEquivalentPath } from "../i18n/switcher";

export interface Props {
  currentLocale: Locale;
  currentPath?: string;
}

const { currentLocale, currentPath = "/" } = Astro.props;
const otherLocale = SITE_CONFIG.locales.find((l) => l !== currentLocale)!;
const detectedLocale = detectLocale(currentPath);
const effectiveLocale = detectedLocale || currentLocale;

const navLinks = [
  { href: resolveRoute(effectiveLocale, "/"), labelKey: "nav.home" },
  { href: resolveRoute(effectiveLocale, "/about"), labelKey: "nav.about" },
  { href: resolveRoute(effectiveLocale, "/services"), labelKey: "nav.services" },
  { href: resolveRoute(effectiveLocale, "/pricing"), labelKey: "nav.pricing" },
  { href: resolveRoute(effectiveLocale, "/blog"), labelKey: "nav.blog" },
  { href: resolveRoute(effectiveLocale, "/contact"), labelKey: "nav.contact" },
];

const switcherHref = getEquivalentPath(currentPath, otherLocale);
---

<header class="header">
  <nav class="header__nav container" aria-label={t(effectiveLocale, "nav.home")}>
    <a href={resolveRoute(effectiveLocale, "/")} class="header__logo">
      {SITE_CONFIG.name}
    </a>

    <ul class="header__links">
      {navLinks.map((link) => (
        <li><a href={link.href}>{t(effectiveLocale, link.labelKey)}</a></li>
      ))}
    </ul>

    <a
      href={switcherHref}
      class="header__locale-switch"
      hreflang={otherLocale}
    >
      {t(effectiveLocale, "locale.switch")}
    </a>
  </nav>
</header>

<style>
  .header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg-primary);
  }

  .header__nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
  }

  .header__logo {
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .header__links {
    display: flex;
    gap: var(--space-lg);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .header__links a {
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    padding: var(--space-xs) 0;
    border-bottom: 2px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .header__links a:hover {
    color: var(--color-brand-primary);
    border-bottom-color: var(--color-brand-primary);
  }

  .header__locale-switch {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-brand-primary);
    text-decoration: none;
    padding: var(--space-xs) var(--space-sm);
    border: 1px solid var(--color-brand-primary);
    border-radius: 0.375rem;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .header__locale-switch:hover {
    background: var(--color-brand-primary);
    color: white;
  }
</style>
