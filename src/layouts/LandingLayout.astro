---
import BaseLayout from "./BaseLayout.astro";
import SEO from "../components/seo/SEO.astro";
import { type Locale } from "../lib/site-config";

export interface Props {
  title: string;
  description: string;
  locale: Locale;
  path: string;
}

const { title, description, locale, path } = Astro.props as Props;
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  path={path}
  showHeader={false}
  showFooter={false}
>
  <SEO
    slot="seo"
    title={title}
    description={description}
    locale={locale}
    path={path}
    ogImage={path === "/" ? `/og/home/${locale}` : `/og/page/${locale}${path}`}
  />
  <slot />
</BaseLayout>
