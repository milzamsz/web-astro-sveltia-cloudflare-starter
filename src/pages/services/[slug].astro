---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { t } from "../../i18n/ui";
import { resolveRoute } from "../../i18n/routes";
import { canonicalUrl, jsonLdService } from "../../lib/seo";
import CTA from "../../components/CTA.astro";

export async function getStaticPaths() {
  const allServices: CollectionEntry<"services">[] = await getCollection("services");
  return allServices.map((service) => ({
    params: { slug: service.data.slug },
    props: { service, locale: service.data.locale },
  }));
}

const { service, locale } = Astro.props as {
  service: CollectionEntry<"services">;
  locale: "id" | "en";
};
const title = service.data.title;
const description = service.data.description;

const serviceJsonLd = jsonLdService({
  name: title,
  description,
  locale,
  url: canonicalUrl(locale, `/services/${service.data.slug}`),
});
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  path={`/services/${service.data.slug}`}
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceJsonLd)} />

  <article class="service-detail container">
    <header class="service-detail__header">
      <a href={resolveRoute(locale, "/services")} class="service-detail__back">
        &larr; {t(locale, "nav.services")}
      </a>
      <h1>{title}</h1>
      <p class="service-detail__desc">{description}</p>
      {service.data.priceRange && (
        <span class="service-detail__price">{service.data.priceRange}</span>
      )}
    </header>

    <section class="service-detail__features">
      <h2>{locale === "id" ? "Fitur" : "Features"}</h2>
      <ul>
        {service.data.features.map((feature: string) => (
          <li>{feature}</li>
        ))}
      </ul>
    </section>

    <CTA
      title={locale === "id" ? "Tertarik dengan layanan ini?" : "Interested in this service?"}
      content={locale === "id"
        ? "Hubungi kami untuk diskusi lebih lanjut."
        : "Contact us for a detailed discussion."}
      ctaText={locale === "id" ? "Hubungi Kami" : "Contact Us"}
      ctaHref="/contact"
      locale={locale}
    />
  </article>
</BaseLayout>

<style>
  .service-detail { padding-block: var(--space-2xl); max-width: 48rem; margin: 0 auto; }
  .service-detail__back { display: inline-block; color: var(--color-text-secondary); text-decoration: none; font-size: 0.9375rem; margin-bottom: var(--space-lg); }
  .service-detail__back:hover { color: var(--color-brand-primary); }
  .service-detail__header h1 { font-size: 2rem; font-weight: 800; line-height: 1.2; margin: 0 0 var(--space-md); }
  .service-detail__desc { font-size: 1.125rem; color: var(--color-text-secondary); margin: 0 0 var(--space-md); line-height: 1.6; }
  .service-detail__price { display: inline-block; font-weight: 700; font-size: 1.5rem; color: var(--color-brand-primary); margin-bottom: var(--space-xl); }
  .service-detail__features { margin-bottom: var(--space-xl); }
  .service-detail__features h2 { font-size: 1.25rem; font-weight: 700; margin: 0 0 var(--space-md); }
  .service-detail__features ul { list-style: none; padding: 0; display: grid; gap: var(--space-sm); }
  .service-detail__features li { padding: var(--space-sm) var(--space-md); background: var(--color-bg-tertiary); border-radius: 0.375rem; font-size: 0.9375rem; }
</style>