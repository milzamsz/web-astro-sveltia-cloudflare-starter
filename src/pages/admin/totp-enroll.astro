---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="2FA Setup"
  description="Enroll in two-factor authentication"
  locale="id"
  path="/admin/totp-enroll"
>
  <main
    class="totp-enroll container"
    style="max-width: 600px; margin: 4rem auto; padding: 2rem;"
  >
    <h1 style="text-align: center; margin-bottom: 1.5rem;">
      Set Up Two-Factor Authentication
    </h1>

    <div id="step1" style="text-align: center;">
      <p>
        1. Scan this QR code with your authenticator app (Google Authenticator,
        Authy, etc.)
      </p>
      <div
        id="qr-container"
        style="background: #f3f4f6; padding: 2rem; border-radius: 8px; margin: 1rem 0;"
      >
        <p style="color: #666;">Loading QR code...</p>
      </div>
      <p style="font-size: 0.875rem; color: #666;">
        Or enter the secret manually in your app.
      </p>
      <pre
        id="secret-display"
        style="background: #1f2937; color: #10b981; padding: 0.75rem; border-radius: 4px; font-size: 0.875rem; letter-spacing: 2px; user-select: all; display: none;">
      </pre>

      <p style="margin-top: 1rem;">
        2. Enter the 6-digit code from your app below:
      </p>
      <input
        type="text"
        id="totp-code"
        maxlength="6"
        pattern="\d{6}"
        inputmode="numeric"
        placeholder="000000"
        style="width: 200px; padding: 0.75rem; font-size: 1.25rem; text-align: center; letter-spacing: 6px; border: 2px solid #ccc; border-radius: 6px;"
      />
      <br />
      <button
        id="verify-btn"
        disabled
        style="margin-top: 1rem; padding: 0.75rem 2rem; background: var(--primary, #171717); color: var(--primary-foreground, #fff); border: none; border-radius: 6px; cursor: pointer; font-size: 1rem;"
      >
        Verify & Enable 2FA
      </button>

      <p
        id="error-message"
        style="color: red; display: none; margin-top: 1rem;"
      >
      </p>
      <p
        id="success-message"
        style="color: green; display: none; margin-top: 1rem;"
      >
      </p>
    </div>

    <div id="step2" style="display: none; text-align: center;">
      <h2>Backup Codes</h2>
      <p>
        Save these backup codes in a safe place. Each code can only be used
        once.
      </p>
      <div
        id="backup-codes-container"
        style="background: #f3f4f6; padding: 1rem; border-radius: 8px; margin: 1rem 0; font-family: monospace; line-height: 2;"
      >
      </div>
      <button
        id="continue-btn"
        style="padding: 0.75rem 2rem; background: #059669; color: #fff; border: none; border-radius: 6px; cursor: pointer; font-size: 1rem;"
      >
        Continue to Admin
      </button>
    </div>
  </main>

  <script>
    const step1 = document.getElementById("step1") as HTMLElement;
    const step2 = document.getElementById("step2") as HTMLElement;
    const qrContainer = document.getElementById("qr-container") as HTMLElement;
    const secretDisplay = document.getElementById(
      "secret-display",
    ) as HTMLElement;
    const codeInput = document.getElementById("totp-code") as HTMLInputElement;
    const verifyBtn = document.getElementById(
      "verify-btn",
    ) as HTMLButtonElement;
    const errorMsg = document.getElementById("error-message") as HTMLElement;
    const successMsg = document.getElementById(
      "success-message",
    ) as HTMLElement;
    const backupContainer = document.getElementById(
      "backup-codes-container",
    ) as HTMLElement;
    const continueBtn = document.getElementById(
      "continue-btn",
    ) as HTMLButtonElement;

    let totpUri = "";
    let backupCodes: string[] = [];

    // Enable verify button when 6 digits entered
    codeInput?.addEventListener("input", () => {
      verifyBtn!.disabled = codeInput.value.length !== 6;
    });

    // Initialize TOTP enrollment on page load
    (async () => {
      try {
        const res = await fetch("/api/auth/totp/enroll", { method: "POST" });
        const data = await res.json();

        if (!res.ok) {
          qrContainer!.innerHTML = `<p style="color: red;">${data.error}</p>`;
          return;
        }

        totpUri = data.uri;
        backupCodes = data.backupCodes || [];

        // Display secret for manual entry
        secretDisplay!.textContent = data.secret;
        secretDisplay!.style.display = "block";

        // Generate QR code inline
        const encodedUri = encodeURIComponent(totpUri);
        qrContainer!.innerHTML = `
          <img src="https://api.qrserver.com/v1/create-qr-code/?size=250x250&data=${encodedUri}"
               alt="TOTP QR Code"
               style="width: 250px; height: 250px; border-radius: 8px;" />
        `;
      } catch (err) {
        qrContainer!.innerHTML = `<p style="color: red;">Failed to load enrollment data. Are you logged in?</p>`;
      }
    })();

    // Verify TOTP code
    verifyBtn?.addEventListener("click", async () => {
      errorMsg!.style.display = "none";
      successMsg!.style.display = "none";

      try {
        const res = await fetch("/api/auth/totp/verify", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ code: codeInput!.value }),
        });

        const data = await res.json();

        if (!res.ok) {
          errorMsg!.textContent = data.error || "Verification failed";
          errorMsg!.style.display = "block";
          return;
        }

        successMsg!.textContent = "2FA enabled! Save your backup codes below.";
        successMsg!.style.display = "block";

        // Show backup codes
        backupContainer!.innerHTML = backupCodes
          .map((code: string) => `<div>${code}</div>`)
          .join("");

        step1!.style.display = "none";
        step2!.style.display = "block";
      } catch {
        errorMsg!.textContent = "Network error. Please try again.";
        errorMsg!.style.display = "block";
      }
    });

    // Continue to admin
    continueBtn?.addEventListener("click", () => {
      window.location.href = "/admin";
    });
  </script>
</BaseLayout>
