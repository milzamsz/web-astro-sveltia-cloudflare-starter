---
export function getStaticPaths() {
  return [{ params: { locale: "id" } }, { params: { locale: "en" } }];
}

import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { t } from "../../i18n/ui";
import Hero from "../../components/Hero.astro";
import { ServiceCard } from "../../components/services/index";

const locale = (Astro.currentLocale || "id") as "id" | "en";
const isId = locale === "id";

const allServices: CollectionEntry<"services">[] =
  await getCollection("services");
const services = allServices
  .filter((s) => s.data.locale === locale)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title={t(locale, "nav.services")}
  description={isId
    ? "Layanan pengembangan website modern"
    : "Modern website development services"}
  locale={locale}
  path={"/services"}
>
  <Hero
    title={isId ? "Layanan Kami" : "Our Services"}
    content={isId
      ? "Solusi lengkap untuk kebutuhan website marketing Anda."
      : "Complete solutions for your marketing website needs."}
    locale={locale}
  />

  <section class="services-list container">
    {
      services.length === 0 && (
        <p class="services-list__empty">
          {isId ? "Belum ada layanan tersedia." : "No services available yet."}
        </p>
      )
    }
    <div class="services-list__grid">
      {
        services.map((service) => (
          <ServiceCard service={service} locale={locale} headingLevel="h2" />
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .services-list {
    padding-block: var(--space-2xl);
  }

  .services-list__empty {
    color: var(--color-text-secondary);
    text-align: center;
  }

  .services-list__grid {
    display: grid;
    gap: var(--space-xl);
    grid-template-columns: repeat(auto-fill, minmax(22rem, 1fr));
  }
</style>
