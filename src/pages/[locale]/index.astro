---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import Hero from "../../components/Hero.astro";
import FAQ from "../../components/FAQ.astro";
import CTA from "../../components/CTA.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import {
  FeatureTabs,
  StackMarquee,
  Credibility,
  LighthouseScores,
} from "../../components/landing/index";
import { t } from "../../i18n/ui";

const stackEntries = (await getCollection("stack"))
  .sort(
    (a: CollectionEntry<"stack">, b: CollectionEntry<"stack">) =>
      a.data.order - b.data.order,
  )
  .map((entry: CollectionEntry<"stack">) => entry.data);

export function getStaticPaths() {
  return [{ params: { locale: "id" } }, { params: { locale: "en" } }];
}

const locale = (Astro.currentLocale || "id") as "id" | "en";
const isId = locale === "id";
const tabs = [
  {
    id: "performance",
    icon: "zap",
    heading: isId ? "Performa" : "Performance",
    description: isId
      ? "Stack ringan dan cepat di edge."
      : "A lightweight stack optimized for the edge.",
    visual: isId
      ? "Static-first rendering with Cloudflare delivery."
      : "Static-first rendering with Cloudflare delivery.",
  },
  {
    id: "content",
    icon: "pen-line",
    heading: isId ? "Konten" : "Content",
    description: isId
      ? "Konten multilingual dengan workflow CMS."
      : "Multilingual content with a CMS-friendly workflow.",
    visual: isId
      ? "Blog, docs, and services are collection-driven."
      : "Blog, docs, and services are collection-driven.",
  },
  {
    id: "growth",
    icon: "trending-up",
    heading: isId ? "Growth" : "Growth",
    description: isId
      ? "SEO dan structured data siap pakai."
      : "SEO and structured data are built in.",
    visual: isId
      ? "OG images, RSS, sitemap, and rich metadata."
      : "OG images, RSS, sitemap, and rich metadata.",
  },
];
---

<MarketingLayout
  title={t(locale, "nav.home")}
  description={isId
    ? "Boilerplate multilingual untuk website marketing."
    : "Multilingual boilerplate for marketing websites."}
  locale={locale}
  path="/"
>
  <Hero
    variant="centered"
    eyebrow={isId
      ? "Multilingual Marketing Starter"
      : "Multilingual Marketing Starter"}
    headline={t(locale, "hero.title")}
    subheadline={t(locale, "hero.subtitle")}
    primaryCta={{ label: t(locale, "hero.cta"), href: "/services" }}
    secondaryCta={{ label: isId ? "Baca Blog" : "Read Blog", href: "/blog" }}
    locale={locale}
  />

  <section class="container py-16">
    <header class="section-head">
      <p class="section-head__eyebrow">
        {isId ? "Kenapa stack ini" : "Why this stack"}
      </p>
      <h2 class="section-head__title">
        {
          isId
            ? "Dibangun untuk performa dan skala"
            : "Built for performance and scale"
        }
      </h2>
      <p class="section-head__lead">
        {
          isId
            ? "Semua yang Anda butuhkan untuk meluncurkan website marketing yang cepat dan multibahasa."
            : "Everything you need to ship a fast, multilingual marketing site."
        }
      </p>
    </header>
    <FeatureTabs client:visible tabs={tabs} />
  </section>

  <section class="container py-10">
    <header class="section-head">
      <h2 class="section-head__title">
        {isId ? "Didukung teknologi modern" : "Powered by a modern stack"}
      </h2>
    </header>
    <StackMarquee items={stackEntries} />
  </section>

  <section class="container py-16">
    <Credibility
      stats={[
        { value: "55+", label: isId ? "Halaman" : "Pages" },
        { value: "2", label: isId ? "Bahasa" : "Locales" },
        { value: "100%", label: isId ? "Static-first" : "Static-first" },
      ]}
      logos={[
        { name: "Astro", src: undefined },
        { name: "Cloudflare", src: undefined },
        { name: "Tailwind", src: undefined },
      ]}
    />
  </section>

  <section class="container py-16">
    <header class="section-head">
      <h2 class="section-head__title">
        {isId ? "Skor Lighthouse sempurna" : "Perfect Lighthouse scores"}
      </h2>
      <p class="section-head__lead">
        {
          isId
            ? "Skor target, diverifikasi dengan Lighthouse — dioptimalkan sejak awal untuk performa, aksesibilitas, dan SEO."
            : "Target scores, verified with Lighthouse — optimized out of the box for performance, accessibility, and SEO."
        }
      </p>
    </header>
    <LighthouseScores />
  </section>

  <FAQ
    title={isId ? "Pertanyaan Umum" : "Frequently Asked Questions"}
    items={[
      {
        question: isId ? "Apakah ini multibahasa?" : "Is this multilingual?",
        answer: isId
          ? "Ya, English dan Indonesian sudah disiapkan."
          : "Yes, English and Indonesian are ready out of the box.",
      },
      {
        question: isId ? "Apakah SEO sudah siap?" : "Is SEO ready?",
        answer: isId
          ? "Meta, sitemap, RSS, dan OG image sudah terhubung."
          : "Meta tags, sitemap, RSS, and OG images are connected.",
      },
    ]}
  />

  <CTA
    title={isId ? "Siap melanjutkan?" : "Ready to go further?"}
    content={isId
      ? "Jelajahi layanan atau baca dokumentasi untuk memulai."
      : "Explore the services or read the docs to get started."}
    ctaText={isId ? "Lihat Layanan" : "View Services"}
    ctaHref="/services"
    locale={locale}
  />
</MarketingLayout>
