---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { t } from "../i18n/ui";

const locale = (Astro.currentLocale || "id") as "id" | "en";

const allPages: CollectionEntry<"pages">[] = await getCollection("pages");
const page = allPages.find(
  (p) => p.data.slug === "privacy" && p.data.locale === locale,
);
---

<BaseLayout
  title={page?.data.title || t(locale, "footer.privacy")}
  description={page?.data.description}
  locale={locale}
  path={"/privacy"}
>
  <article class="legal-page container">
    <h1>{page?.data.title}</h1>
    <div class="legal-page__content">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .legal-page {
    padding-block: var(--space-2xl);
    max-width: 48rem;
    margin: 0 auto;
  }
  .legal-page h1 {
    font-size: 2rem;
    font-weight: 800;
    margin: 0 0 var(--space-xl);
  }
  .legal-page__content {
    line-height: 1.8;
    color: var(--color-text-secondary);
  }
  .legal-page__content h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: var(--space-xl) 0 var(--space-md);
  }
  .legal-page__content ul {
    padding-left: var(--space-lg);
  }
  .legal-page__content li {
    margin-bottom: var(--space-sm);
  }
</style>
