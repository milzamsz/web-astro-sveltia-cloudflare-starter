---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { t } from "../i18n/ui";

const locale = (Astro.currentLocale || "en") as "id" | "en";

const allPosts: CollectionEntry<"blog">[] = await getCollection("blog");
const posts = allPosts
  .filter((p) => p.data.locale === locale && !p.data.draft)
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

// Collect all unique tags
const allTags = [...new Set(posts.flatMap((p) => p.data.tags || []))];
---

<BaseLayout title={t(locale, "nav.blog")} description={t(locale, "nav.blog")} locale={locale}>
  <main class="container py-12 max-w-5xl mx-auto">
    <header class="mb-10">
      <h1 class="text-4xl font-bold tracking-tight">{t(locale, "nav.blog")}</h1>
      <p class="mt-3 text-lg text-muted-foreground">
        {locale === "en"
          ? "Articles about web development, multilingual sites, and the modern stack."
          : "Artikel tentang pengembangan web, situs multilingual, dan stack modern."}
      </p>
    </header>

    {allTags.length > 0 && (
      <nav class="mb-8 flex flex-wrap gap-2" aria-label="Filter by tag">
        {allTags.map((tag) => (
          <span class="rounded-full bg-primary/10 text-primary px-4 py-1.5 text-sm font-medium cursor-default">
            {tag}
          </span>
        ))}
      </nav>
    )}

    {posts.length === 0 && (
      <div class="rounded-lg border bg-muted/50 p-12 text-center">
        <p class="text-lg text-muted-foreground">
          {locale === "en" ? "No blog posts yet. Check back soon!" : "Belum ada artikel blog. Pantau terus!"}
        </p>
      </div>
    )}

    <div class="grid gap-8 md:grid-cols-2">
      {posts.map((post, index) => {
        const dateStr = new Date(post.data.publishDate).toLocaleDateString(
          locale === "id" ? "id-ID" : "en-US",
          { year: "numeric", month: "long", day: "numeric" },
        );
        return (
          <article class={`group rounded-xl border bg-card p-6 shadow-sm transition-shadow hover:shadow-md ${index === 0 ? "md:col-span-2" : ""}`}>
            <div class="flex items-center gap-3 text-sm text-muted-foreground">
              <time datetime={post.data.publishDate}>{dateStr}</time>
              <span>·</span>
              <span>{post.data.author}</span>
            </div>
            <h2 class={`mt-3 font-semibold text-card-foreground group-hover:text-primary transition-colors ${index === 0 ? "text-2xl" : "text-xl"}`}>
              <a href={`/blog/${post.id}`} class="hover:underline">
                {post.data.title}
              </a>
            </h2>
            <p class="mt-2 text-muted-foreground leading-relaxed">
              {post.data.description}
            </p>
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="mt-4 flex flex-wrap gap-2">
                {post.data.tags.map((tag: string) => (
                  <span class="rounded-full bg-secondary px-3 py-1 text-xs text-secondary-foreground">{tag}</span>
                ))}
              </div>
            )}
            <div class="mt-4">
              <a href={`/blog/${post.id}`} class="text-sm font-medium text-primary group-hover:underline">
                {locale === "en" ? "Read more →" : "Baca selengkapnya →"}
              </a>
            </div>
          </article>
        );
      })}
    </div>
  </main>
</BaseLayout>
