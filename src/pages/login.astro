---
import BaseLayout from "../layouts/BaseLayout.astro";
import { TURNSTILE_SITE_KEY } from "astro:env/server";

// Turnstile site keys are public by design, so it's safe to bake this into the
// page at build time. Falls back to Cloudflare's "always passes" TEST key when
// no real key is configured (local dev / unconfigured deploy).
const turnstileSiteKey = TURNSTILE_SITE_KEY || "1x00000000000000000000AA";
---

<BaseLayout
  title="Login"
  description="Admin login page"
  locale="id"
  path="/login"
>
  <main
    class="login-page container"
    style="max-width: 400px; margin: 4rem auto; padding: 2rem;"
  >
    <h1 style="text-align: center; margin-bottom: 1.5rem;">Login</h1>

    <form
      id="login-form"
      style="display: flex; flex-direction: column; gap: 1rem;"
    >
      <div>
        <label
          for="email"
          style="display: block; margin-bottom: 0.25rem; font-weight: 600;"
          >Email</label
        >
        <input
          type="email"
          id="email"
          name="email"
          required
          placeholder="admin@example.com"
          style="width: 100%; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;"
        />
      </div>

      <div>
        <label
          for="password"
          style="display: block; margin-bottom: 0.25rem; font-weight: 600;"
          >Password</label
        >
        <input
          type="password"
          id="password"
          name="password"
          required
          placeholder="••••••••"
          style="width: 100%; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;"
        />
      </div>

      <div
        id="turnstile-container"
        data-sitekey={turnstileSiteKey}
        style="display: flex; justify-content: center;"
      >
      </div>

      <button
        type="submit"
        style="padding: 0.75rem; background: var(--primary, #171717); color: var(--primary-foreground, #fff); border: none; border-radius: 6px; cursor: pointer; font-size: 1rem;"
      >
        Sign In
      </button>

      <p
        id="error-message"
        style="color: red; display: none; text-align: center;"
      >
      </p>
      <p
        id="success-message"
        style="color: green; display: none; text-align: center;"
      >
      </p>
    </form>
  </main>

  <script>
    const form = document.getElementById("login-form") as HTMLFormElement;
    const errorEl = document.getElementById("error-message") as HTMLElement;
    const successEl = document.getElementById("success-message") as HTMLElement;
    const turnstileContainer = document.getElementById(
      "turnstile-container",
    ) as HTMLElement | null;
    const siteKey = turnstileContainer?.dataset.sitekey || "";

    let turnstileToken = "";

    // Load the Turnstile script and render the widget. For explicit render the
    // callbacks must be functions (string names only work with implicit
    // data-callback rendering), so we close over `turnstileToken` directly.
    const turnstileScript = document.createElement("script");
    turnstileScript.src =
      "https://challenges.cloudflare.com/turnstile/v0/api.js";
    turnstileScript.async = true;
    turnstileScript.defer = true;
    turnstileScript.onload = () => {
      if (turnstileContainer && (window as any).turnstile && siteKey) {
        (window as any).turnstile.render(turnstileContainer, {
          sitekey: siteKey,
          callback: (token: string) => {
            turnstileToken = token;
          },
          "expired-callback": () => {
            turnstileToken = "";
          },
          "error-callback": () => {
            turnstileToken = "";
          },
          theme: "auto",
          action: "login",
        });
      }
    };
    document.head.appendChild(turnstileScript);

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      errorEl.style.display = "none";
      successEl.style.display = "none";

      if (siteKey && !turnstileToken) {
        errorEl.textContent = "Please complete the verification.";
        errorEl.style.display = "block";
        return;
      }

      const email = (document.getElementById("email") as HTMLInputElement)
        .value;
      const password = (document.getElementById("password") as HTMLInputElement)
        .value;

      try {
        const res = await fetch("/api/auth/sign-in", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            email,
            password,
            "cf-turnstile-response": turnstileToken,
          }),
        });

        const data = await res.json();

        if (!res.ok) {
          errorEl.textContent = data.error || "Login failed";
          errorEl.style.display = "block";
          // Turnstile tokens are single-use — reset so the user can retry.
          turnstileToken = "";
          (window as any).turnstile?.reset();
          return;
        }

        successEl.textContent = "Login successful! Redirecting...";
        successEl.style.display = "block";

        // Check if 2FA is required
        if (data.requires2FA) {
          window.location.href = "/admin/totp-enroll";
        } else {
          const returnUrl =
            new URLSearchParams(window.location.search).get("return_to") ||
            "/admin";
          window.location.href = returnUrl;
        }
      } catch {
        errorEl.textContent = "Network error. Please try again.";
        errorEl.style.display = "block";
        turnstileToken = "";
        (window as any).turnstile?.reset();
      }
    });
  </script>
</BaseLayout>
